# ══════════════════════════════════════════════════════════════════
#  Karen — Secretária IA  |  Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores reais.
#  NUNCA commite o arquivo .env no repositório.
# ══════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────
# URL do projeto Supabase (encontrada em Project Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Chave pública (anon) — usada apenas em contexto de cliente
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave de serviço — acesso total ao banco sem RLS (mantenha secreta!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# String de conexão direta ao PostgreSQL (para migrações, asyncpg etc.)
# Formato: postgresql://postgres:[SENHA]@db.[REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxxxxxxxxxx.supabase.co:5432/postgres


# ── WhatsApp / Meta Cloud API ────────────────────────────────────
# Token de verificação definido por você no painel da Meta
# (Configurações do Webhook → Verify Token)
META_VERIFY_TOKEN=seu_token_de_verificacao_aqui

# Segredo do aplicativo Meta — usado para validar assinatura HMAC
# (Painel Meta for Developers → Seu App → Configurações Básicas → Segredo do aplicativo)
META_APP_SECRET=seu_app_secret_aqui

# Token de acesso do sistema (permanente) gerado no painel da Meta
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID do número de telefone WhatsApp Business
# (Painel Meta → WhatsApp → Configuração da API → ID do número de telefone)
WHATSAPP_PHONE_NUMBER_ID=1234567890123456

# ID da conta comercial do WhatsApp
# (Painel Meta → WhatsApp → Configuração da API → ID da conta comercial do WhatsApp)
WHATSAPP_BUSINESS_ACCOUNT_ID=1234567890123456


# ── IA / LLM ──────────────────────────────────────────────────────
# Chave da OpenRouter — usada para Claude e GPT-4o-mini via proxy
# (openrouter.ai → Keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chave da OpenAI — usada diretamente para embeddings (text-embedding-3-small)
# (platform.openai.com → API Keys)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Google Calendar ───────────────────────────────────────────────
# ID do calendário Google onde as consultas serão criadas
# (Google Calendar → Configurações do calendário → ID do calendário)
GOOGLE_CALENDAR_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@group.calendar.google.com

# Caminho para o arquivo JSON de credenciais da Service Account
# (Google Cloud Console → IAM → Contas de serviço → Chaves)
GOOGLE_CREDENTIALS_PATH=credentials.json


# ── Redis ─────────────────────────────────────────────────────────
# URL de conexão ao Redis
# Formato local:  redis://localhost:6379
# Formato remoto: redis://default:[SENHA]@[HOST]:[PORTA]
REDIS_URL=redis://localhost:6379


# ── Ambiente ──────────────────────────────────────────────────────
# "development" ou "production"
# Em development: CORS aberto, logs mais verbosos
APP_ENV=development

# Porta onde o servidor irá rodar
APP_PORT=8000
